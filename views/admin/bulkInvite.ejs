<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Bulk Invitation • CampusNotes</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "primary": "#FF5722", 
            "background-dark": "#050505",
            "surface-dark": "#0A0A0A", 
            "surface-dark-lighter": "#171717",
            "border-dark": "#27272A",
          }
        },
      },
    }
  </script>
  <style>
    body { background-color: #050505; color: #e5e7eb; font-family: 'Inter', sans-serif; }
    .glass-card {
      background: rgba(10, 10, 10, 0.6);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }
  </style>
</head>
<body class="min-h-screen p-4 mt-14 md:p-8">
  <div class="max-w-4xl mx-auto space-y-8">
    
    <!-- Header -->
    <div class="flex items-center gap-4">
      <a href="/dashboard" class="p-2 bg-surface-dark-lighter border border-border-dark rounded-lg text-gray-400 hover:text-white transition-colors">
        <i class="fa-solid fa-arrow-left"></i>
      </a>
      <div>
        <h1 class="text-2xl font-bold text-white tracking-tight">Bulk Student Invitation</h1>
        <p class="text-gray-500 text-sm">Send professional invitations to students who haven't joined yet.</p>
      </div>
    </div>

    <% if (typeof success !== 'undefined' && success.length > 0) { %>
      <div class="p-4 rounded-xl bg-green-500/10 border border-green-500/20 text-green-500 flex items-center gap-3">
        <i class="fa-solid fa-check-circle"></i>
        <span><%= success %></span>
      </div>
    <% } %>

    <% if (typeof error !== 'undefined' && error.length > 0) { %>
      <div class="p-4 rounded-xl bg-red-500/10 border border-red-500/20 text-red-500 flex items-center gap-3">
        <i class="fa-solid fa-circle-exclamation"></i>
        <span><%= error %></span>
      </div>
    <% } %>

    <!-- Form -->
    <div class="glass-card rounded-2xl p-6 md:p-8 space-y-6">
      <form action="/dashboard/bulk-invite" method="POST" class="space-y-6">
        <div>
          <label class="block text-sm font-medium text-gray-400 mb-2">Student List (Name, Email)</label>
          <p class="text-xs text-gray-600 mb-3 italic">Format: John Doe, john@example.com (one student per line)</p>
          <textarea 
            name="studentData" 
            rows="12" 
            class="w-full bg-surface-dark-lighter border border-border-dark rounded-xl p-4 text-white placeholder-gray-600 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all font-mono text-sm"
            placeholder="Rahul Patidar, rahul@gmail.com
Sushmita Sen, sush@example.com"
            required></textarea>
        </div>

        <div class="p-4 rounded-xl bg-primary/5 border border-primary/10 space-y-2">
          <h3 class="text-sm font-semibold text-primary flex items-center gap-2">
            <i class="fa-solid fa-info-circle"></i> What they'll receive:
          </h3>
          <ul class="text-xs text-gray-400 space-y-1 ml-6 list-disc">
            <li>Personalized greeting with their name.</li>
            <li>Platform stats: Total Users, Notes, and Downloads.</li>
            <li>Call to action: Invite to provide <strong>6th Semester</strong> notes.</li>
          </ul>
        </div>

        <div class="flex items-center justify-between pt-4">
          <p class="text-xs text-gray-500 max-w-[300px]">
            Emails will be queued and sent gradually to maintain high deliverability and avoid spam filters.
          </p>
          <button type="submit" class="bg-primary hover:bg-primary-hover text-white font-bold py-3 px-8 rounded-xl shadow-lg shadow-primary/20 transition-all flex items-center gap-2">
            <i class="fa-solid fa-paper-plane"></i> Send Invitations
          </button>
        </div>
      </form>
    </div>

  </div>
</body>
</html>
